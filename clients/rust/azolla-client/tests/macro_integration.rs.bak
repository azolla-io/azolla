/// Test the purpose of macro integration: ensure the #[azolla_task] proc macro works correctly
/// Test the expected behavior: macro should generate proper Task implementations and handle various argument patterns

#[cfg(feature = "macros")]
mod macro_tests {
    use azolla_client::{
        azolla_task,
        task::{BoxedTask, Task, TaskResult},
        TaskError,
    };
    use serde_json::json;
    use std::sync::Arc;

    // Test macro with simple argument structure
    #[derive(serde::Deserialize, Debug)]
    struct SimpleArgs {
        value: i32,
    }

    #[azolla_task]
    async fn simple_macro_task(args: SimpleArgs) -> TaskResult {
        Ok(json!({
            "doubled": args.value * 2,
            "task_type": "simple_macro"
        }))
    }

    // Test macro with no arguments
    #[azolla_task]
    async fn no_args_macro_task() -> TaskResult {
        Ok(json!({
            "message": "No arguments needed",
            "timestamp": chrono::Utc::now().to_rfc3339()
        }))
    }

    // Test macro with complex nested arguments
    #[derive(serde::Deserialize, Debug)]
    struct ComplexArgs {
        user_id: String,
        settings: UserSettings,
        metadata: Vec<MetadataItem>,
    }

    #[derive(serde::Deserialize, Debug)]
    struct UserSettings {
        notifications: bool,
        theme: String,
    }

    #[derive(serde::Deserialize, Debug)]
    struct MetadataItem {
        key: String,
        value: String,
    }

    #[azolla_task]
    async fn complex_macro_task(args: ComplexArgs) -> TaskResult {
        Ok(json!({
            "user_id": args.user_id,
            "notifications_enabled": args.settings.notifications,
            "theme": args.settings.theme,
            "metadata_count": args.metadata.len(),
            "processed": true
        }))
    }

    // Test macro with fallible task (returns error)
    #[derive(serde::Deserialize, Debug)]
    struct ValidationArgs {
        email: String,
        age: i32,
    }

    #[azolla_task]
    async fn validation_macro_task(args: ValidationArgs) -> TaskResult {
        if !args.email.contains('@') {
            return Err(TaskError::invalid_args("Invalid email format"));
        }
        if args.age < 18 || args.age > 120 {
            return Err(TaskError::invalid_args("Age must be between 18 and 120"));
        }

        Ok(json!({
            "email": args.email,
            "age": args.age,
            "status": "valid"
        }))
    }

    // Test macro with tuple arguments
    #[azolla_task]
    async fn tuple_macro_task(args: (String, i32, bool)) -> TaskResult {
        let (text, number, flag) = args;
        Ok(json!({
            "text": text,
            "number": number,
            "flag": flag,
            "combined": format!("{}-{}-{}", text, number, flag)
        }))
    }

    // Mock chrono module for timestamp generation
    mod chrono {
        pub struct Utc;
        impl Utc {
            pub fn now() -> DateTime {
                DateTime
            }
        }

        pub struct DateTime;
        impl DateTime {
            pub fn to_rfc3339(&self) -> String {
                "2023-01-01T00:00:00Z".to_string()
            }
        }
    }

    /// Test that macro generates correct Task implementation
    #[test]
    fn test_macro_task_name() {
        let task = simple_macro_task;
        assert_eq!(task.name(), "simple_macro_task");

        let no_args_task = no_args_macro_task;
        assert_eq!(no_args_task.name(), "no_args_macro_task");

        let complex_task = complex_macro_task;
        assert_eq!(complex_task.name(), "complex_macro_task");
    }

    /// Test macro-generated task execution with simple arguments
    #[tokio::test]
    async fn test_simple_macro_task_execution() {
        let task = simple_macro_task;
        let args = SimpleArgs { value: 21 };

        let result = task.execute(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["doubled"], 42);
        assert_eq!(output["task_type"], "simple_macro");
    }

    /// Test macro-generated task execution with no arguments
    #[tokio::test]
    async fn test_no_args_macro_task_execution() {
        let task = no_args_macro_task;

        let result = task.execute(()).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["message"], "No arguments needed");
        assert!(output["timestamp"].is_string());
    }

    /// Test macro-generated task with complex arguments
    #[tokio::test]
    async fn test_complex_macro_task_execution() {
        let task = complex_macro_task;
        let args = ComplexArgs {
            user_id: "user-123".to_string(),
            settings: UserSettings {
                notifications: true,
                theme: "dark".to_string(),
            },
            metadata: vec![
                MetadataItem {
                    key: "lang".to_string(),
                    value: "en".to_string(),
                },
                MetadataItem {
                    key: "region".to_string(),
                    value: "us-west".to_string(),
                },
            ],
        };

        let result = task.execute(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["user_id"], "user-123");
        assert_eq!(output["notifications_enabled"], true);
        assert_eq!(output["theme"], "dark");
        assert_eq!(output["metadata_count"], 2);
        assert_eq!(output["processed"], true);
    }

    /// Test macro-generated task with validation (success case)
    #[tokio::test]
    async fn test_validation_macro_task_success() {
        let task = validation_macro_task;
        let args = ValidationArgs {
            email: "user@example.com".to_string(),
            age: 25,
        };

        let result = task.execute(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["email"], "user@example.com");
        assert_eq!(output["age"], 25);
        assert_eq!(output["status"], "valid");
    }

    /// Test macro-generated task with validation (failure case)
    #[tokio::test]
    async fn test_validation_macro_task_failure() {
        let task = validation_macro_task;

        // Test invalid email
        let invalid_email_args = ValidationArgs {
            email: "invalid-email".to_string(),
            age: 25,
        };

        let result = task.execute(invalid_email_args).await;
        assert!(result.is_err());
        let error = result.unwrap_err();
        assert_eq!(error.error_type, "InvalidArguments");
        assert!(error.message.contains("Invalid email format"));

        // Test invalid age
        let invalid_age_args = ValidationArgs {
            email: "valid@example.com".to_string(),
            age: 150,
        };

        let result = task.execute(invalid_age_args).await;
        assert!(result.is_err());
        let error = result.unwrap_err();
        assert_eq!(error.error_type, "InvalidArguments");
        assert!(error.message.contains("Age must be between 18 and 120"));
    }

    /// Test macro-generated task with tuple arguments
    #[tokio::test]
    async fn test_tuple_macro_task_execution() {
        let task = tuple_macro_task;
        let args = ("hello".to_string(), 42, true);

        let result = task.execute(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["text"], "hello");
        assert_eq!(output["number"], 42);
        assert_eq!(output["flag"], true);
        assert_eq!(output["combined"], "hello-42-true");
    }

    /// Test macro-generated task as BoxedTask
    #[test]
    fn test_macro_task_as_boxed_task() {
        let simple_task: Arc<dyn BoxedTask> = Arc::new(simple_macro_task);
        assert_eq!(simple_task.name(), "simple_macro_task");

        let complex_task: Arc<dyn BoxedTask> = Arc::new(complex_macro_task);
        assert_eq!(complex_task.name(), "complex_macro_task");
    }

    /// Test macro-generated BoxedTask execution
    #[tokio::test]
    async fn test_macro_boxed_task_execution() {
        let task: Arc<dyn BoxedTask> = Arc::new(simple_macro_task);
        let args = vec![json!({"value": 15})];

        let result = task.execute_json(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["doubled"], 30);
    }

    /// Test macro-generated task argument parsing
    #[test]
    fn test_macro_task_parse_args() {
        // Test simple task argument parsing
        let simple_args = vec![json!({"value": 100})];
        let result = simple_macro_task::parse_args(simple_args);
        assert!(result.is_ok());
        let parsed = result.unwrap();
        assert_eq!(parsed.value, 100);

        // Test no-args task parsing
        let no_args = vec![];
        let result = no_args_macro_task::parse_args(no_args);
        assert!(result.is_ok());

        // Test complex task argument parsing
        let complex_args = vec![json!({
            "user_id": "test-user",
            "settings": {
                "notifications": false,
                "theme": "light"
            },
            "metadata": [
                {"key": "test", "value": "value"}
            ]
        })];
        let result = complex_macro_task::parse_args(complex_args);
        assert!(result.is_ok());
        let parsed = result.unwrap();
        assert_eq!(parsed.user_id, "test-user");
        assert_eq!(parsed.settings.theme, "light");
        assert_eq!(parsed.metadata.len(), 1);
    }

    /// Test macro-generated task with invalid arguments
    #[tokio::test]
    async fn test_macro_task_invalid_arguments() {
        let task: Arc<dyn BoxedTask> = Arc::new(simple_macro_task);
        let invalid_args = vec![json!("not-an-object")];

        let result = task.execute_json(invalid_args).await;
        assert!(result.is_err());

        let error = result.unwrap_err();
        assert_eq!(error.error_type, "InvalidArguments");
    }

    /// Test that macro-generated tasks work in collections
    #[test]
    fn test_macro_tasks_in_collections() {
        let mut tasks: Vec<Arc<dyn BoxedTask>> = Vec::new();

        tasks.push(Arc::new(simple_macro_task));
        tasks.push(Arc::new(no_args_macro_task));
        tasks.push(Arc::new(complex_macro_task));
        tasks.push(Arc::new(validation_macro_task));
        tasks.push(Arc::new(tuple_macro_task));

        assert_eq!(tasks.len(), 5);

        // Verify all tasks have correct names
        assert_eq!(tasks[0].name(), "simple_macro_task");
        assert_eq!(tasks[1].name(), "no_args_macro_task");
        assert_eq!(tasks[2].name(), "complex_macro_task");
        assert_eq!(tasks[3].name(), "validation_macro_task");
        assert_eq!(tasks[4].name(), "tuple_macro_task");
    }

    /// Test macro-generated task Send + Sync bounds
    #[test]
    fn test_macro_task_thread_safety() {
        // Test in Arc (requires Send + Sync) - use the generated Task structs
        let _task1: Arc<dyn BoxedTask> = Arc::new(SimpleMacroTaskTask);
        let _task2: Arc<dyn BoxedTask> = Arc::new(ComplexMacroTaskTask);
        let _task3: Arc<dyn BoxedTask> = Arc::new(NoArgsMacroTaskTask);

        // If this compiles, it proves the tasks are Send + Sync
        println!("All macro-generated tasks are Send + Sync");
    }
}

// Tests that should work regardless of macro feature
#[test]
fn test_macro_feature_conditional_compilation() {
    #[cfg(feature = "macros")]
    {
        // When macros feature is enabled, the macro should be available
        use azolla_client::azolla_task;

        // This should compile
        #[azolla_task]
        async fn feature_test_task() -> azolla_client::TaskResult {
            Ok(serde_json::json!({"status": "macro_available"}))
        }

        assert_eq!(FeatureTestTaskTask.name(), "feature_test_task");
    }

    #[cfg(not(feature = "macros"))]
    {
        // When macros feature is disabled, we can still test that the feature works
        // by checking that the macro is not available in the public API
        // This test mainly ensures the conditional compilation works
        println!("Macros feature is disabled - macro tests skipped");
    }
}

#[cfg(feature = "macros")]
/// Test edge cases in macro argument handling
mod macro_edge_cases {
    use azolla_client::{azolla_task, TaskError, TaskResult};
    use serde_json::json;

    // Test with Option arguments
    #[derive(serde::Deserialize, Debug)]
    struct OptionalArgs {
        required: String,
        optional: Option<i32>,
    }

    #[azolla_task]
    async fn optional_args_task(args: OptionalArgs) -> TaskResult {
        Ok(json!({
            "required": args.required,
            "optional": args.optional,
            "has_optional": args.optional.is_some()
        }))
    }

    // Test with Vec arguments
    #[azolla_task]
    async fn vec_args_task(args: Vec<String>) -> TaskResult {
        Ok(json!({
            "items": args,
            "count": args.len()
        }))
    }

    // Test with generic Result return
    #[azolla_task]
    async fn result_task(args: String) -> Result<serde_json::Value, TaskError> {
        if args.is_empty() {
            Err(TaskError::invalid_args("String cannot be empty"))
        } else {
            Ok(json!({"input": args, "length": args.len()}))
        }
    }

    #[tokio::test]
    async fn test_optional_args_with_some() {
        let task = optional_args_task;
        let args = OptionalArgs {
            required: "test".to_string(),
            optional: Some(42),
        };

        let result = task.execute(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["required"], "test");
        assert_eq!(output["optional"], 42);
        assert_eq!(output["has_optional"], true);
    }

    #[tokio::test]
    async fn test_optional_args_with_none() {
        let task = optional_args_task;
        let args = OptionalArgs {
            required: "test".to_string(),
            optional: None,
        };

        let result = task.execute(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["required"], "test");
        assert!(output["optional"].is_null());
        assert_eq!(output["has_optional"], false);
    }

    #[tokio::test]
    async fn test_vec_args_task() {
        let task = vec_args_task;
        let args = vec!["a".to_string(), "b".to_string(), "c".to_string()];

        let result = task.execute(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["count"], 3);
        assert!(output["items"].is_array());
    }

    #[tokio::test]
    async fn test_result_task_success() {
        let task = result_task;
        let args = "hello world".to_string();

        let result = task.execute(args).await;
        assert!(result.is_ok());

        let output = result.unwrap();
        assert_eq!(output["input"], "hello world");
        assert_eq!(output["length"], 11);
    }

    #[tokio::test]
    async fn test_result_task_error() {
        let task = result_task;
        let args = "".to_string();

        let result = task.execute(args).await;
        assert!(result.is_err());

        let error = result.unwrap_err();
        assert_eq!(error.error_type, "InvalidArguments");
        assert!(error.message.contains("String cannot be empty"));
    }
}
